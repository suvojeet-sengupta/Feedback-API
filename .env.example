# ─── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── API Security ─────────────────────────────────
# Optional API key to protect your endpoints
# Leave empty to disable API key authentication
API_KEY=your-secret-api-key-here

# ─── Database ──────────────────────────────────────
# SQLite is used by default (no setup needed)
# The database file will be created automatically
DB_PATH=./data/feedback.sqlite

# ─── Telegram Bot ──────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYz

# Get your chat ID by messaging @userinfobot on Telegram
# Can be a user ID, group ID, or channel ID
TELEGRAM_CHAT_ID=123456789

# Enable/disable Telegram notifications (true/false)
TELEGRAM_ENABLED=true

# ─── Rate Limiting ─────────────────────────────────
# Max feedback submissions per IP per window
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
